flowchart TD
    subgraph Endpoints["API Endpoints"]
        EP1[GET /price]
        EP2[GET /history]
        EP3[GET /fundamentals]
        EP4[GET /etf]
        EP5[GET /dividends]
        EP6[POST /sync\nNEW v1.1.0]
        EP7[GET /providers/status]
    end

    subgraph Providers["External Providers"]
        POL[Polygon.io\nPrice primary]
        FMP[FMP\nFundamentals + Dividends]
        YFI[yfinance\nFallback]
        FIN[Finnhub\nCredit Rating\nNEW v1.1.0]
    end

    subgraph Compute["Derived Fields (v1.1.0)"]
        CH[chowder_number\n= yield_ttm + div_cagr_5y]
        Y5[yield_5yr_avg\n= avg 5yr annual yield]
        CQ[credit_quality_proxy\nrating → coverage → NULL]
    end

    subgraph DB["platform_shared (PostgreSQL)"]
        SEC[(securities\nTEXT PK)]
        FH[(features_historical\nsymbol + date)]
        PD[(price / price_history)]
    end

    subgraph Cache["Valkey Cache"]
        VC[TTL = health_score_ttl_hours]
    end

    EP1 --> POL --> FMP --> YFI --> VC & PD
    EP2 --> POL --> FMP --> YFI --> PD
    EP3 --> FMP --> YFI
    EP3 -->|lazy upsert\nfire-and-forget| SEC
    EP4 --> FMP --> YFI
    EP4 -->|lazy upsert\nfire-and-forget| SEC
    EP5 --> FMP --> YFI

    EP6 --> FMP --> YFI
    EP6 --> FIN
    FMP --> CH & Y5
    FIN --> CQ
    FMP -->|interest_coverage fallback| CQ
    CH & Y5 & CQ --> FH
    EP6 --> SEC

    EP7 --> POL & FMP & YFI & FIN
