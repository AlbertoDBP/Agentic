# ── Database ──────────────────────────────────────────────────────────────────
# DigitalOcean Dashboard → Databases → income-fortress-postgres → Connection Details
# The asyncpg driver requires postgresql+asyncpg:// prefix (not plain postgresql://)
DATABASE_URL=postgresql+asyncpg://USERNAME:PASSWORD@HOST:25060/DATABASE
DB_SCHEMA=platform_shared
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Cache ─────────────────────────────────────────────────────────────────────
# DigitalOcean Dashboard → Databases → income-fortress-valkey → Connection Details
REDIS_URL=rediss://default:PASSWORD@HOST:25061

# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared HS256 signing secret — must be identical across ALL services.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Internal service-to-service bearer token
SERVICE_TOKEN=

# ── Market Data Providers ─────────────────────────────────────────────────────
# Financial Modeling Prep (primary provider)  https://financialmodelingprep.com
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api/v3
FMP_CALLS_PER_MINUTE=300
FMP_REQUEST_TIMEOUT=30

# Finnhub (tertiary fallback)  https://finnhub.io
FINNHUB_API_KEY=

# ── AI Providers ──────────────────────────────────────────────────────────────
# Anthropic Claude — newsletter signal extraction
ANTHROPIC_API_KEY=
ANTHROPIC_CALLS_PER_MINUTE=60
EXTRACTION_MODEL=claude-sonnet-4-6
EXTRACTION_MAX_TOKENS=4096
PHILOSOPHY_MODEL=claude-sonnet-4-6
PHILOSOPHY_MAX_TOKENS=2048

# OpenAI — embeddings (pgvector semantic search)
OPENAI_API_KEY=
OPENAI_CALLS_PER_MINUTE=60
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Seeking Alpha / Newsletter Ingestion (Agent 02) ───────────────────────────
# RapidAPI → Seeking Alpha plan  https://rapidapi.com/apidojo/api/seeking-alpha
APIDOJO_SA_API_KEY=
APIDOJO_SA_HOST=seeking-alpha.p.rapidapi.com
SA_ACCESS_TOKEN=
SA_CALLS_PER_MINUTE=30
SA_REQUEST_TIMEOUT=30
SA_FETCH_LIMIT_PER_ANALYST=10

# ── Inter-Service URLs ────────────────────────────────────────────────────────
# Docker Compose service names resolve automatically inside the network
MARKET_DATA_SERVICE_URL=http://market-data-service:8001
NEWSLETTER_SERVICE_URL=http://agent-02-newsletter-ingestion:8002

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
